MONGO_URI=mongodb://localhost:27017
DB_NAME=shipment_db
JWT_SECRET_KEY=your-secret-key
ENCRYPTION_KEY=your-fernet-key

# AI
OPENAI_API_KEY=your-openai-key

# Weather — https://openweathermap.org/appid (Free: 60 req/min)
OPENWEATHER_API_KEY=your-openweathermap-key

# Currency — https://app.exchangerate-api.com/sign-up (Free: 1,500 req/month)
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key

# Flights — https://aviationstack.com/signup/free (Free: 100 req/month, HTTP only)
AVIATIONSTACK_API_KEY=your-aviationstack-key

# Fuel — https://www.eia.gov/opendata/register.php (Free, no limits)
EIA_API_KEY=your-eia-api-key

# Maps / Routing — https://openrouteservice.org/dev/#/login (Free: 2,000 req/day)
ORS_API_KEY=your-openrouteservice-key

# Traffic — https://developer.tomtom.com/user/register (Free: 2,500 req/day)
TOMTOM_API_KEY=your-tomtom-api-key

# Ports — IMF PortWatch (No key needed — open access)
